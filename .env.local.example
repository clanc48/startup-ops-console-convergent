# Supabase (client-safe)
NEXT_PUBLIC_SUPABASE_URL=https://YOURPROJECT.supabase.co
# Supabase Dashboard -> Project Settings -> API -> Publishable key
# (During migration, a legacy anon key may also work here)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# SERVER ONLY (do not expose)
# Supabase Dashboard -> Project Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# SERVER ONLY (AI executive summary generation)
OPENAI_API_KEY=your_openai_key_here

# SERVER ONLY (protect /api/jobs/worker in production)
WORKER_TOKEN=use-a-long-random-string-here
