# Supabase (client-safe)
# Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOURPROJECT.supabase.co

# Supabase Dashboard -> Project Settings -> API -> Publishable key
# Legacy anon key (JWT starting with eyJ...) may also work.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# --------------------------------------------------------------------------------------
# SERVER ONLY (do not expose these in the browser)
# --------------------------------------------------------------------------------------

# Supabase Dashboard -> Project Settings -> API -> service_role key
# Used for admin operations in server routes / setup scripts.
SUPABASE_SERVICE_ROLE_KEY=eyJ_your_service_role_jwt_here

# Optional: enables AI executive summary generation.
# If unset/blank, AI features (and the jobs worker) are effectively disabled.
OPENAI_API_KEY=

# Optional: protects `POST /api/jobs/worker` in production.
# In dev, the worker endpoint is open for demo convenience.
WORKER_TOKEN=

# Optional: enables extra server debug logging in API routes.
# The launch wizard sets this to1 automatically.
DEBUG_SERVER=1
